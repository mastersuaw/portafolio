---
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <img
    class="hero-bg"
    src={`${base}images/hero-bg.svg`}
    alt=""
    width="1200"
    height="400"
    aria-hidden="true"
  />
  <div class="container hero-content">
    <p class="hero-tagline">Creador de apps y sitios web</p>
    <h1>mastersuaw</h1>
    <p class="hero-description">
      Desarrollador independiente de aplicaciones móviles y sitios web. Creo herramientas
      prácticas, experiencias digitales y productos listos para publicar en las tiendas de Apple y
      Google.
    </p>
    <div class="hero-links">
      <a href={`${base}#proyectos`} class="btn btn-primary">Ver proyectos</a>
      <a
        href="https://github.com/mastersuaw"
        class="btn btn-outline"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
