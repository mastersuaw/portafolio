---
interface Props {
  title: string;
  appName: string;
  appSlug: string;
  updated: string;
}

const { title, appName, appSlug, updated } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article class="legal-page container">
  <a href={`${base}apps/${appSlug}`} class="back-link">&larr; Volver a {appName}</a>
  <h1>{title}</h1>
  <p class="legal-updated">Última actualización: {updated}</p>
  <slot />
</article>
