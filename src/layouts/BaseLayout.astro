---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'mastersuaw — Creador de apps y sitios web', ogImage } = Astro.props;
const fullTitle = title === 'mastersuaw' ? title : `${title} | mastersuaw`;
const base = import.meta.env.BASE_URL;
const ogImageUrl = ogImage ?? `${base}og-image.png`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="mastersuaw" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href={base} class="brand">
          <img src={`${base}images/brand-mark.svg`} alt="" width="32" height="32" />
          <span>mastersuaw</span>
        </a>
        <nav>
          <ul class="nav-links">
            <li><a href={base}>Inicio</a></li>
            <li><a href={`${base}#proyectos`}>Proyectos</a></li>
            <li>
              <a href="https://github.com/mastersuaw" target="_blank" rel="noopener noreferrer"
                >GitHub</a
              >
            </li>
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} mastersuaw. Todos los derechos reservados.</p>
        <p>
          <a
            href="https://github.com/mastersuaw/portafolio"
            target="_blank"
            rel="noopener noreferrer">Código fuente</a
          >
        </p>
      </div>
    </footer>
  </body>
</html>
